# ─── GitHub 업로드 제외: 데이터 파일 (용량·재현 가능) ───
data/raw/*.csv
data/processed/
data/*.csv
!data/.gitkeep

# ─── 학습된 모델 (용량 큼, 사용자가 직접 학습) ───
models/checkpoints/
models/ppo_agents/
models/regime_classifier/*.json
models/regime_classifier/*.ubj
models/walk_forward/
models/walk_forward_sma/
models/walk_forward_sma_longonly/
models/walk_forward_reward_v2/
models/walk_forward_reward_v2_full/

# ─── 결과/로그 (재실행으로 생성 가능) ───
results/backtest/*.pkl
results/logs/*.log
results/verification/*.log
results/verification/*.json
results/plots/*.png
results/plots/*.html
results/verification/improvement_history.json
results/verification/progress_reach_100.json

# walk-forward: keep MD / JSON summaries (small), drop raw logs and pickles.
results/walk_forward/*.log
results/walk_forward/fold_*/*.pkl
results/walk_forward/fold_*/*.log
results/walk_forward_sma/*.log
results/walk_forward_sma/fold_*/*.pkl
results/walk_forward_sma/fold_*/*.log
results/walk_forward_sma_longonly/*.log
results/walk_forward_sma_longonly/fold_*/*.pkl
results/walk_forward_sma_longonly/fold_*/*.log
results/walk_forward_reward_v2/*.log
results/walk_forward_reward_v2/fold_*/*.pkl
results/walk_forward_reward_v2/fold_*/*.log
results/walk_forward_reward_v2_full/*.log
results/walk_forward_reward_v2_full/fold_*/*.pkl
results/walk_forward_reward_v2_full/fold_*/*.log

# ─── 설정 백업 (업로드 불필요) ───
config/config_backup_iter_*.yaml

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
*.egg-info/
.eggs/
dist/
build/

